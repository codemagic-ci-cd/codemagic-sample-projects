{
  "testRunner": "jest",
  "runnerConfig": "e2e/config.json",
  "apps": {
    "android.debug": {
      "type": "android.apk",
      "binaryPath": "android/app/build/outputs/apk/debug/app-debug.apk",
      "build": "cd android && ./gradlew assembleDebug assembleAndroidTest -DtestBuildType=debug && cd .."
    },
    "android.release": {
      "type": "android.apk",
      "binaryPath": "android/app/build/outputs/apk/release/app-release.apk",
      "build": "cd android && ./gradlew assembleRelease assembleAndroidTest -DtestBuildType=release && cd .."
    },
    "ios.debug": {
      "type": "ios.app",
      "binaryPath": "ios/build/Build/Products/Debug-iphonesimulator/ReactNativeDetox.app",
      "build": "xcodebuild -workspace ios/ReactNativeDetox.xcworkspace -scheme ReactNativeDetox -configuration Debug -sdk iphonesimulator -derivedDataPath ios/build clean build ONLY_ACTIVE_ARCH=YES"
    },
    "ios.release": {
      "type": "ios.app",
      "binaryPath": "ios/build/Build/Products/Release-iphonesimulator/ReactNativeDetox.app",
      "build": "export RCT_NO_LAUNCH_PACKAGER=true && xcodebuild -workspace ios/ReactNativeDetox.xcworkspace -scheme ReactNativeDetox -configuration Release -sdk iphonesimulator -derivedDataPath ios/build clean build ONLY_ACTIVE_ARCH=YES"
    }
  },
  "devices": {
    "emulator": {
      "type": "android.emulator",
      "device": {
        "avdName": "emulator-36"
      }
    },
    "simulator": {
      "type": "ios.simulator",
      "device": {
        "type": "iPhone 16"
      }
    }
  },
  "configurations": {
    "android.emu.debug": {
      "device": "emulator",
      "app": "android.debug"
    },
    "android.emu.release": {
      "device": "emulator",
      "app": "android.release"
    },
    "ios.sim.debug": {
      "device": "simulator",
      "app": "ios.debug"
    },
    "ios.sim.release": {
      "device": "simulator",
      "app": "ios.release"
    }
  }
}